# ─── Supabase ──────────────────────────────────────────────────────────────────
# Project URL — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key — safe to expose to the browser (RLS enforces security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — NEVER expose to the browser. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── OpenAI ────────────────────────────────────────────────────────────────────
# Used only for embeddings (text-embedding-3-small). Server-side only.
OPENAI_API_KEY=sk-...

# ─── DeepSeek ──────────────────────────────────────────────────────────────────
# Chat completions (deepseek-chat / DeepSeek V3). Get key at platform.deepseek.com
DEEPSEEK_API_KEY=sk-...

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Assistente de Pesquisa Dowbor.org"
